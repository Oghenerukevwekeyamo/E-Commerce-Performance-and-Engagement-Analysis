   "source": [
    "## Data Cleaning & Feature Engineering"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "e51403de",
   "metadata": {},
   "outputs": [],
   "source": [
    "customers['Date'] = pd.to_datetime(customers['Date'], errors='coerce')\n",
    "customers['Year'] = customers['Date'].dt.year"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "9a42c969",
   "metadata": {},
   "outputs": [],
   "source": [
    "customers['Date'] = pd.to_datetime(customers['Date'], errors='coerce')\n",
    "customers['Month'] = customers['Date'].dt.month"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "fe4e9c48",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "0       Medium\n",
       "1       Medium\n",
       "2       Medium\n",
       "3       Medium\n",
       "4         High\n",
       "         ...  \n",
       "4995      High\n",
       "4996    Medium\n",
       "4997      High\n",
       "4998      High\n",
       "4999    Medium\n",
       "Name: engagement_level, Length: 5000, dtype: object"
      ]
     },
     "execution_count": 11,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "# Engagement Level\n",
    "conditions = [\n",
    "    (customers['Pages_Viewed'] <= 3) & \n",
    "    (customers['Session_Duration_Minutes'] <= 5),\n",
    "\n",
    "    (customers['Pages_Viewed'].between(4,7)) & \n",
    "    (customers['Session_Duration_Minutes'].between(6,15)),\n",
    "\n",
    "    (customers['Pages_Viewed'] > 7) & \n",
    "    (customers['Session_Duration_Minutes'] > 15)\n",
    "]\n",
    "\n",
    "choices = ['Low', 'Medium', 'High']\n",
    "\n",
    "customers['engagement_level'] = np.select(conditions, choices, default='Medium')\n",
    "customers['engagement_level']"
   ]
  },
